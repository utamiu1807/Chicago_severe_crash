        "# Deduplicate\n",
        "if 'CRASH_RECORD_ID' in df.columns:\n",
        "    before_dup = len(df)\n",
        "    df = df.drop_duplicates(subset=['CRASH_RECORD_ID'])\n",
        "    print('Duplicates removed:', before_dup - len(df))\n",
